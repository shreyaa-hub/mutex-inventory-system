generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLevels  StockLevel[]
  reservations Reservation[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())

  stockLevels  StockLevel[]
  reservations Reservation[]
}

// tracks available + reserved stock per product per warehouse
model StockLevel {
  id          String @id @default(cuid())
  productId   String
  warehouseId String
  totalUnits  Int    @default(0)
  reserved    Int    @default(0)   // units currently held by pending reservations

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model Reservation {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int
  status      ReservationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // for idempotency bonus
  idempotencyKey String? @unique

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}
